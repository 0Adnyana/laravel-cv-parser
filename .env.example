# Used as OpenRouter X-Title header when parsing CVs
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Used as OpenRouter HTTP-Referer header when parsing CVs
# In production behind a reverse proxy, set this to your public HTTPS URL.
APP_URL=http://localhost

# Trust reverse-proxy headers (Caddy, NPM, Traefik). Required for Docker/reverse-proxy deployments.
# Use * when the app is only reachable via a trusted proxy. Comma-separate IPs/CIDRs to restrict.
TRUSTED_PROXIES=

# Octane (FrankenPHP) — used by Docker and production long-lived servers
OCTANE_SERVER=frankenphp

# OpenRouter CV parser (required for /api/v1/parse)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Optional: defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: cloudflare-ai, mistral-ocr, or native (default: cloudflare-ai)
# OPENROUTER_PDF_ENGINE=cloudflare-ai
# Optional: per-request HTTP timeout in seconds (default: 60)
# OPENROUTER_REQUEST_TIMEOUT=60
# Optional: PHP max execution time for /api/v1/parse in seconds (default: 240)
# OPENROUTER_PARSE_TIME_LIMIT=240

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# When the app runs in Docker but the database runs on your host machine, use host.docker.internal instead of 127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
